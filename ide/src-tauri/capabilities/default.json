{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-create-dir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    "fs:allow-stat",
    "http:default",
    "http:allow-fetch",
    "shell:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "store:default",
    "store:allow-set",
    "store:allow-get",
    "store:allow-delete",
    "store:allow-clear",
    "store:allow-entries",
    "store:allow-keys",
    "store:allow-values",
    "store:allow-length",
    "store:allow-load",
    "store:allow-save"
  ]
}
